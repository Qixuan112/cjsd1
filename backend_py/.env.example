# Flask 环境配置
# 可选值: development, production, testing
FLASK_ENV=development

# 数据库配置
# MySQL 连接 URL 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/plugin_marketplace

# JWT 密钥配置
# 用于签名 JWT Token，生产环境请使用强随机字符串
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# GitHub OAuth 配置
# 在 GitHub Settings -> Developer settings -> OAuth Apps 中创建
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Flask 服务端口
FLASK_PORT=5000

# ============================================
# 可选配置（使用默认值可不配置）
# ============================================

# Flask 密钥（用于 session 等）
# 如果不设置，会使用 JWT_SECRET_KEY
# SECRET_KEY=your-flask-secret-key

# 跨域配置
# 多个来源用逗号分隔，如: http://localhost:3000,http://localhost:8080
# 生产环境建议限制具体来源
CORS_ORIGINS=*

# 日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 开发环境数据库（可选，覆盖默认配置）
# DEV_DATABASE_URL=mysql+pymysql://root:root@localhost/dev_db
